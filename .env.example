# ==============================================
# ListtenBook 听书知识库项目配置
# ==============================================
# 复制本文件为 .env 后按需修改

# ---------- LLM（OpenAI 兼容，用 SiliconFlow/DashScope 都行）----------
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.siliconflow.cn/v1
LLM_DEFAULT_MODEL=Pro/moonshotai/Kimi-K2.5
# 书名/作者识别专用模型（可以跟 LLM_DEFAULT_MODEL 一样）
BOOK_RECOGNITION_MODEL=Pro/moonshotai/Kimi-K2.5
LLM_DEFAULT_TEMPERATURE=0.1

# ---------- Embedding（BGE-M3，本地路径）----------
BGE_M3_PATH=/Users/heisen/Desktop/学习/models/bge-m3
BGE_DEVICE=cpu
BGE_FP16=False

# ---------- Reranker（可选，本地路径）----------
BGE_RERANKER_PATH=/Users/heisen/Desktop/学习/models/bge_reranker_large
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_FP16=False

# ---------- Milvus ----------
MILVUS_URL=http://127.0.0.1:19530
# 听书知识库主集合（切片）
CHUNKS_COLLECTION=lb_chunks
# 书籍名称集合（用于书名对齐识别）
BOOK_NAME_COLLECTION=lb_book_names

# ---------- MongoDB（对话历史）----------
MONGO_URL=mongodb://admin:123456@127.0.0.1:27017
MONGO_DB_NAME=listten_book

# ---------- Redis 缓存 ----------
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=True
# 缓存过期时间（秒），默认 1 小时
CACHE_EXPIRE_SECONDS=3600

# ---------- 向量 & 切分参数 ----------
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=8
MAX_CHUNK_LENGTH=1500
MIN_CHUNK_LENGTH=300

# ---------- 检索参数 ----------
HYBRID_SEARCH_LIMIT=8
RERANK_MAX_TOP_K=6
RERANK_MIN_TOP_K=3
MAX_CONTEXT_CHARS=8000

# ---------- 书名识别阈值 ----------
BOOK_NAME_HIGH_CONFIDENCE=0.7
BOOK_NAME_MID_CONFIDENCE=0.45
BOOK_NAME_SCORE_GAP=0.15
BOOK_NAME_MAX_OPTIONS=3